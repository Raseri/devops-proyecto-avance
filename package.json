{
    "name": "tienda-manager-backend",
    "version": "1.0.0",
    "description": "Backend API para Tienda Manager",
    "type": "module",
    "main": "server.js",
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "start": "node server.js",
        "dev": "node --watch server.js",
        "build": "cd frontend && npm install && npm run build",
        "test": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --detectOpenHandles"
    },
    "keywords": [
        "api",
        "express",
        "mysql",
        "tienda"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "jsonwebtoken": "^9.0.2",
        "mysql2": "^3.9.1"
    },
    "devDependencies": {
        "cross-env": "^10.1.0",
        "jest": "^30.2.0",
        "supertest": "^7.2.2"
    }
}